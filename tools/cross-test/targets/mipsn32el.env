# Target descriptor: MIPS n32 ABI little-endian (32-bit pointers, 64-bit registers).
# See mipsn32.env for the multilib gcc/binutils story.

ARCH=mipsn32el
TRIPLE=mips64el-linux-gnuabi64
QEMU=qemu-mipsn32el-static
CFLAGS="-O2 -mabi=n32 -DSSF_CONFIG_HAVE_OPENSSL=0"
LDFLAGS="-mabi=n32 -lm -lpthread -static"
