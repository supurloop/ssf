# Target descriptor: Motorola 68000 family, Linux glibc.
# m68k is hardcoded big-endian and has no 64-bit variant, so this is the only
# m68k cell available to the matrix.
# See mipsel.env for the variable contract.

ARCH=m68k
TRIPLE=m68k-linux-gnu
QEMU=qemu-m68k-static
CFLAGS="-O2 -DSSF_CONFIG_HAVE_OPENSSL=0"
LDFLAGS="-lm -lpthread -static"
