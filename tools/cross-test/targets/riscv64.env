# Target descriptor: RISC-V 64-bit little-endian, Linux glibc, LP64D.
# Debian doesn't ship a riscv32 cross toolchain, so 64-bit LE is the only
# RISC-V cell currently covered.
# See mipsel.env for the variable contract.

ARCH=riscv64
TRIPLE=riscv64-linux-gnu
QEMU=qemu-riscv64-static
CFLAGS="-O2 -DSSF_CONFIG_HAVE_OPENSSL=0"
LDFLAGS="-lm -lpthread -static"
