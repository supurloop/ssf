# Target descriptor: PowerPC 32-bit big-endian (classic ppc), Linux glibc.
# qemu-ppc-static and qemu-powerpc-static are the same binary.
# See mipsel.env for the variable contract.

ARCH=powerpc
TRIPLE=powerpc-linux-gnu
QEMU=qemu-ppc-static
CFLAGS="-O2 -DSSF_CONFIG_HAVE_OPENSSL=0"
LDFLAGS="-lm -lpthread -static"
