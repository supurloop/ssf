# Target descriptor: x86 32-bit (i686) little-endian, Linux glibc.
# qemu binary is qemu-i386-static (i386 covers the whole x86-32 family in qemu).
# See mipsel.env for the variable contract.

ARCH=i686
TRIPLE=i686-linux-gnu
QEMU=qemu-i386-static
CFLAGS="-O2 -DSSF_CONFIG_HAVE_OPENSSL=0"
LDFLAGS="-lm -lpthread -static"
