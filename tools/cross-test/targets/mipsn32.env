# Target descriptor: MIPS n32 ABI big-endian (32-bit pointers, 64-bit registers).
# Driven via the n64 gcc with -mabi=n32 — Debian doesn't ship a dedicated
# gcc-mips64-linux-gnuabin32 package, but gcc-mips64-linux-gnuabi64 has
# multilib support for n32 (verified via --print-multi-lib). The n32 binutils
# and libc-dev packages must be installed alongside.
# See mipsel.env for the variable contract.

ARCH=mipsn32
TRIPLE=mips64-linux-gnuabi64
QEMU=qemu-mipsn32-static
CFLAGS="-O2 -mabi=n32 -DSSF_CONFIG_HAVE_OPENSSL=0"
LDFLAGS="-mabi=n32 -lm -lpthread -static"
