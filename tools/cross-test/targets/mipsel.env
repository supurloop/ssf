# Target descriptor: MIPS 32-bit little-endian, Linux glibc, soft-fp ABI.
#
# Adding a new target = drop a sibling file alongside this one, populate
# the same five variables, and apt-install the matching gcc cross-toolchain
# in tools/cross-test/docker/Dockerfile.
#
# ARCH      — short tag used as the build dir suffix and binary name suffix.
# TRIPLE    — gcc cross-toolchain triple. Must be present in the Docker image.
# QEMU      — qemu-user binary that matches TRIPLE's machine type. Used to
#             run the built ssf binary on the (non-target) host kernel.
# CFLAGS    — appended to cflags_common in the generated ninja. -O2 is the
#             default; cross builds skip -O3 to keep emulation cycles down.
#             SSF_CONFIG_HAVE_OPENSSL=0 disables the OpenSSL cross-check
#             paths in ssfbn_ut / ssfec_ut / ssfecdsa_ut.
# LDFLAGS   — link flags. -static avoids any target-side libc dance: the
#             ELF runs under qemu-user against the host kernel directly.

ARCH=mipsel
TRIPLE=mipsel-linux-gnu
QEMU=qemu-mipsel-static
CFLAGS="-O2 -DSSF_CONFIG_HAVE_OPENSSL=0"
LDFLAGS="-lm -lpthread -static"
